generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Workspace {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String
  members     Member[]
  owners      Owner[]
  services    Service[]
  incidents   Incident[]
  drills      Drill[]
}

model Member {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  email       String    @unique
  role        String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Owner {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  email       String
  team        String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  services    Service[]
}

model Service {
  id            String               @id @default(cuid())
  workspaceId   String
  ownerId       String
  slug          String
  name          String
  summary       String
  environment   String
  tier          String
  status        String
  workspace     Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  owner         Owner                @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  links         ServiceLink[]
  dependencies  ServiceDependency[]  @relation("FromService")
  dependents    ServiceDependency[]  @relation("ToService")
  runbooks      Runbook[]
  incidents     IncidentService[]
  drills        DrillService[]

  @@unique([workspaceId, slug])
}

model ServiceLink {
  id        String  @id @default(cuid())
  serviceId String
  label     String
  url       String
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model ServiceDependency {
  id              String  @id @default(cuid())
  fromServiceId   String
  toServiceId     String
  fromService     Service @relation("FromService", fields: [fromServiceId], references: [id], onDelete: Cascade)
  toService       Service @relation("ToService", fields: [toServiceId], references: [id], onDelete: Cascade)

  @@unique([fromServiceId, toServiceId])
}

model Runbook {
  id                 String   @id @default(cuid())
  serviceId          String
  title              String
  summary            String
  body               String
  reviewedAt         DateTime
  reviewCadenceDays  Int
  updatedAt          DateTime @updatedAt
  version            Int
  service            Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model Incident {
  id           String                  @id @default(cuid())
  workspaceId  String
  title        String
  severity     String
  status       String
  openedAt     DateTime
  closedAt     DateTime?
  summary      String
  workspace    Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  services     IncidentService[]
  timeline     IncidentTimelineEntry[]
  postmortem   Postmortem?
}

model IncidentService {
  incidentId String
  serviceId  String
  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  service    Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([incidentId, serviceId])
}

model IncidentTimelineEntry {
  id         String   @id @default(cuid())
  incidentId String
  occurredAt DateTime
  kind       String
  body       String
  author     String
  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
}

model Postmortem {
  id                  String          @id @default(cuid())
  incidentId          String          @unique
  title               String
  summary             String
  incident            Incident        @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  contributingFactors ContributingFactor[]
  followUps           FollowUpTask[]
}

model ContributingFactor {
  id           String      @id @default(cuid())
  postmortemId String
  value        String
  postmortem   Postmortem  @relation(fields: [postmortemId], references: [id], onDelete: Cascade)
}

model FollowUpTask {
  id           String      @id @default(cuid())
  postmortemId String
  title        String
  owner        String
  dueAt        DateTime?
  status       String
  postmortem   Postmortem  @relation(fields: [postmortemId], references: [id], onDelete: Cascade)
}

model Drill {
  id           String          @id @default(cuid())
  workspaceId  String
  title        String
  kind         String
  performedAt  DateTime
  facilitator  String
  outcome      String
  notes        String
  workspace    Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  services     DrillService[]
  evidence     DrillEvidence[]
}

model DrillService {
  drillId   String
  serviceId String
  drill     Drill   @relation(fields: [drillId], references: [id], onDelete: Cascade)
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([drillId, serviceId])
}

model DrillEvidence {
  id       String   @id @default(cuid())
  drillId  String
  label    String
  url      String
  notes    String?
  drill    Drill    @relation(fields: [drillId], references: [id], onDelete: Cascade)
}

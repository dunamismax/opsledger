{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@opsledger/config": ["packages/config/src/index.ts"],
      "@opsledger/contracts": ["packages/contracts/src/index.ts"],
      "@opsledger/core": ["packages/core/src/index.ts"],
      "@opsledger/db": ["packages/db/src/index.ts"],
      "@opsledger/testing": ["packages/testing/src/index.ts"]
    }
  }
}
